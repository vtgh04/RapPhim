# Cấu hình kết nối Database MySQL
# Sao chép file này thành database.properties và chỉnh sửa theo môi trường của bạn

# URL kết nối
db.url=jdbc:mysql://localhost:3306/rapphim_db?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Ho_Chi_Minh&useSSL=false&allowPublicKeyRetrieval=true

# Thông tin đăng nhập
db.username=root
db.password=your_password_here

# Tên database
db.name=rapphim_db
